{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "https://redshiftfun.org/$1"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": ""
                },
                {
                    "key": "Content-Security-Policy",
                    "value": ""
                }
            ]
        }
    ]
}